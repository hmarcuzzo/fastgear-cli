[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "Project description goes here."
authors = [
    { name = "Your Name", email = "your_email@email.com"}
]
readme = "README.md"
requires-python = ">=3.11"
dependencies = [
{%- for dep in dependencies %}
    "{{ dep }}",
{%- endfor %}
]


[tool.uv]
default-groups = []

[dependency-groups]
dev = [
    # ----------------------------------------
    # Testing
    # ----------------------------------------
    "httpx>=0.28.1",
    "pytest>=9.0.2",
    "pytest-asyncio>=1.3.0",
    "pytest-cov>=6.2.1",
    "pytest-testdox>=3.1.0",

    # ----------------------------------------
    # Code quality
    # ----------------------------------------
    "poethepoet>=0.32",
    "pre-commit>=4.5.1",
    "ruff>=0.15.0",
]

[tool.poe.tasks]
"test"       = "pytest tests"
"test:unit"  = "pytest tests/unit"


# ==== pytest ====
[tool.pytest.ini_options]
minversion = "6.0"
addopts = "-ra -q --force-testdox --cov=src --cov-branch --cov-report=html"
testpaths = ["tests/"]
