# --------------- APP CONFIGURATION --------------- #
APP_ENV="local"
APP_TZ="UTC"
APP_PORT=8000

CORS_ORIGINS=["*"]

{% if database_provider in ['Postgresql'] -%}
# --------------- DATABASE CONNECTION --------------- #
DATABASE_CONNECTION="postgresql+asyncpg"
DATABASE_HOST="localhost"
DATABASE_PORT=5432
DATABASE_USERNAME="{{ project_name }}_database"
DATABASE_NAME="{{ project_name }}"
DATABASE_PASSWORD="{{ project_name }}_database_password"
{% endif -%}